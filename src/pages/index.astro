---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Ticker from '../components/Ticker.astro';
import Services from '../components/Services.astro';
import Proof from '../components/Proof.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<Navbar />
	<Hero />
	<About />
	<Ticker />
	<Services />
	<Proof />
	<Contact />
	<Footer />
</Layout>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// Reveal on scroll — IntersectionObserver for .reveal and .reveal-stagger
	const revealElements = document.querySelectorAll('.reveal, .reveal-stagger');

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
	);

	revealElements.forEach((el) => observer.observe(el));

	// GSAP: Hero intro — badge drops, title lines slice up, sub+CTAs fade
	const heroTl = gsap.timeline({ defaults: { ease: 'power4.out' } });

	heroTl
		.from('.hero__badge', {
			y: 16,
			opacity: 0,
			duration: 0.5,
		})
		.from('.hero__title .hero__title-line', {
			y: '105%',
			opacity: 0,
			duration: 0.65,
			stagger: 0.1,
		}, '-=0.2')
		.from('.hero__sub', {
			y: 20,
			opacity: 0,
			duration: 0.5,
		}, '-=0.25')
		.from('.hero__actions', {
			y: 16,
			opacity: 0,
			duration: 0.45,
		}, '-=0.3');

	// GSAP: Parallax on hero video
	gsap.to('.hero__video', {
		yPercent: 20,
		ease: 'none',
		scrollTrigger: {
			trigger: '.hero',
			start: 'top top',
			end: 'bottom top',
			scrub: true,
		},
	});

	// GSAP: Stats numbers count-up
	const statNumbers = document.querySelectorAll('.stats__number');

	statNumbers.forEach((el) => {
		const htmlEl = el as HTMLElement;
		const rawText = htmlEl.textContent || '';
		const suffix = rawText.replace(/[\d.]/g, '');
		const target = parseFloat(rawText) || 0;

		// Lock the element's final width before animation so layout won't shift
		htmlEl.style.minWidth = htmlEl.offsetWidth + 'px';
		htmlEl.style.display = 'inline-block';

		ScrollTrigger.create({
			trigger: htmlEl,
			start: 'top 85%',
			once: true,
			onEnter: () => {
				const obj = { val: 0 };
				gsap.to(obj, {
					val: target,
					duration: 2,
					ease: 'power2.out',
					onUpdate: () => {
						htmlEl.textContent = Math.round(obj.val) + suffix;
					},
				});
			},
		});
	});

	// GSAP: Accordion panels fade in
	gsap.utils.toArray<HTMLElement>('.accordion__item').forEach((item) => {
		gsap.from(item, {
			y: 30,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out',
			scrollTrigger: {
				trigger: item,
				start: 'top 85%',
				once: true,
			},
		});
	});

	// GSAP: Smooth parallax on proof image break
	gsap.to('.proof__image-img', {
		yPercent: 10,
		ease: 'none',
		scrollTrigger: {
			trigger: '.proof__image-break',
			start: 'top bottom',
			end: 'bottom top',
			scrub: true,
		},
	});

	// GSAP: Testimonial cards stagger
	gsap.utils.toArray<HTMLElement>('.testimonial-card').forEach((card, i) => {
		gsap.from(card, {
			y: 40,
			opacity: 0,
			duration: 0.7,
			delay: i * 0.1,
			ease: 'power2.out',
			scrollTrigger: {
				trigger: '.testimonial-marquee',
				start: 'top 80%',
				once: true,
			},
		});
	});
</script>
