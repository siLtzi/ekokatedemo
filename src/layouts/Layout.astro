---
import '@fontsource-variable/instrument-sans/wght.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Ekokate — Turvallinen katto, vuosiksi eteenpäin',
	description = 'Olemme erikoistuneet tiili- ja peltikattojen pinnoituskäsittelyihin, katon huoltoon ja remontointiin sekä stretch sisäkattojen asennukseen.',
} = Astro.props;
---

<!doctype html>
<html lang="fi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* Primary palette */
		--green-deep: #2D5016;
		--green-dark: #1A3A0A;
		--green-accent: #4A7A1A;
		--green-bright: #6B9B1E;

		/* Neutrals */
		--stone: #F5F2ED;
		--stone-dark: #E8E4DD;
		--charcoal: #1C1C1E;
		--charcoal-light: #2A2A2C;
		--white: #FFFFFF;
		--text-primary: #1C1C1E;
		--text-secondary: #4A4A4C;
		--text-muted: #7A7A7C;

		/* Typography */
		--font-display: 'Instrument Sans Variable', 'Instrument Sans', sans-serif;
		--font-body: 'Inter', system-ui, sans-serif;

		/* Spacing */
		--section-pad: clamp(80px, 10vw, 160px);
		--section-pad-sm: clamp(48px, 6vw, 80px);
		--container-max: 1280px;
		--container-wide: 1440px;
	}

	*, *::before, *::after {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-size: 16px;
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	body {
		font-family: var(--font-body);
		color: var(--text-primary);
		background: var(--stone);
		line-height: 1.6;
		overflow-x: hidden;
	}

	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-display);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.02em;
	}

	img {
		max-width: 100%;
		height: auto;
		display: block;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 clamp(20px, 4vw, 48px);
	}

	.container--wide {
		max-width: var(--container-wide);
	}

	/* Reveal animation base */
	.reveal {
		opacity: 0;
		transform: translateY(40px);
		transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
					transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.reveal.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* Stagger children */
	.reveal-stagger > * {
		opacity: 0;
		transform: translateY(30px);
		transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
					transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.reveal-stagger.is-visible > *:nth-child(1) { transition-delay: 0s; }
	.reveal-stagger.is-visible > *:nth-child(2) { transition-delay: 0.1s; }
	.reveal-stagger.is-visible > *:nth-child(3) { transition-delay: 0.2s; }
	.reveal-stagger.is-visible > *:nth-child(4) { transition-delay: 0.3s; }
	.reveal-stagger.is-visible > *:nth-child(5) { transition-delay: 0.4s; }

	.reveal-stagger.is-visible > * {
		opacity: 1;
		transform: translateY(0);
	}

	/* ── CTA: Pill → angled parallelogram morph ── */
	.cta {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 13px 28px;
		border: none;
		font-family: var(--font-body);
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		background: var(--green-deep);
		border-radius: 100px;
		color: var(--white);
		cursor: pointer;
		overflow: hidden;
		text-decoration: none;
		transition: border-radius 0.45s cubic-bezier(0.23, 1, 0.32, 1),
					transform 0.45s cubic-bezier(0.23, 1, 0.32, 1),
					box-shadow 0.45s cubic-bezier(0.23, 1, 0.32, 1);
	}

	/* Diagonal sweep — roof-slope angle */
	.cta::before {
		content: '';
		position: absolute;
		inset: -2px;
		background: var(--green-accent);
		transform: translateX(-105%) skewX(-8deg);
		transition: transform 0.45s cubic-bezier(0.23, 1, 0.32, 1);
		z-index: 0;
	}

	.cta:hover {
		border-radius: 4px;
		transform: skewX(-6deg) translateY(-2px);
		box-shadow: 0 6px 24px rgba(45, 80, 22, 0.3);
	}

	.cta:hover::before {
		transform: translateX(0) skewX(0deg);
	}

	/* Counter-skew content so text stays upright */
	.cta span,
	.cta svg {
		position: relative;
		z-index: 1;
		transition: transform 0.45s cubic-bezier(0.23, 1, 0.32, 1);
	}

	.cta svg {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	.cta:hover span,
	.cta:hover svg {
		transform: skewX(6deg);
	}

	.cta:hover svg {
		transform: skewX(6deg) translateX(3px);
	}

	.cta:active {
		transform: skewX(-6deg) translateY(0);
		box-shadow: none;
		transition-duration: 0.15s;
	}

	/* Light variant — bordered on dark backgrounds */
	.cta--light {
		background: transparent;
		box-shadow: inset 0 0 0 1.5px rgba(255,255,255,0.3);
	}

	.cta--light::before {
		background: var(--green-accent);
	}

	.cta--light:hover {
		box-shadow: 0 6px 24px rgba(74, 122, 26, 0.3);
	}

	/* ── Text links with line-draw ── */
	.link {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.9375rem;
		cursor: pointer;
		text-decoration: none;
		color: inherit;
		padding: 4px 0;
		border: none;
		background: none;
	}

	.link::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 1.5px;
		background: currentColor;
		transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.link:hover::after {
		width: 100%;
	}

	.link svg {
		width: 14px;
		height: 14px;
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.link:hover svg {
		transform: translateX(4px);
	}

	.link--light {
		color: rgba(255,255,255,0.7);
	}

	.link--light:hover {
		color: var(--white);
	}

	/* Keep .btn for nav/form submit only */
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.9375rem;
		padding: 14px 28px;
		border-radius: 100px;
		border: none;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		text-decoration: none;
	}

	.btn--primary {
		background: var(--green-accent);
		color: var(--white);
	}

	.btn--primary:hover {
		background: var(--green-deep);
		transform: translateY(-1px);
	}

	/* ── Section label with line ── */
	.section-label {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.75rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--green-accent);
		margin-bottom: 20px;
	}

	.section-label::before {
		content: '';
		display: block;
		width: 24px;
		height: 1.5px;
		background: currentColor;
	}

	/* ── Marquee base ── */
	.marquee {
		overflow: hidden;
		white-space: nowrap;
		padding: 24px 0;
	}

	.marquee__track {
		display: inline-flex;
		animation: marqueeScroll 30s linear infinite;
	}

	.marquee__track:hover {
		animation-play-state: paused;
	}

	@keyframes marqueeScroll {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	/* ── Divider shape ── */
	.divider-angle {
		width: 100%;
		height: clamp(40px, 5vw, 80px);
		display: block;
	}

	/* Smooth scrollbar */
	::-webkit-scrollbar {
		width: 8px;
	}

	::-webkit-scrollbar-track {
		background: var(--stone);
	}

	::-webkit-scrollbar-thumb {
		background: var(--green-deep);
		border-radius: 4px;
	}
</style>
