---
const navLinks = [
	{ label: 'Etusivu', href: '#' },
	{ label: 'Meistä', href: '#meista' },
	{ label: 'Palvelut', href: '#palvelut' },
	{ label: 'Yhteystiedot', href: '#yhteystiedot' },
];
---

<nav class="navbar" id="navbar">
	<!-- Logo tab — lives outside navbar flex flow -->
	<a href="#" class="navbar__logo">
		<img src="/logoekokate.svg" alt="Ekokate" class="navbar__logo-img" />
	</a>

	<div class="navbar__inner container container--wide">
		<!-- spacer div keeps links from sliding under the logo -->
		<div class="navbar__logo-spacer" aria-hidden="true"></div>

		<div class="navbar__links" id="navLinks">
			{navLinks.map(link => (
				<a href={link.href} class="navbar__link">{link.label}</a>
			))}
		</div>

		<div class="navbar__actions">
			<a href="tel:0443636844" class="navbar__phone">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
				044 363 6844
			</a>
			<a href="#yhteystiedot" class="cta cta--light navbar__cta">
				<span>Pyydä tarjous</span>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>

		<button class="navbar__burger" id="navBurger" aria-label="Avaa valikko">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>

	<!-- Mobile overlay -->
	<div class="navbar__mobile" id="navMobile">
		<div class="navbar__mobile-links">
			{navLinks.map(link => (
				<a href={link.href} class="navbar__mobile-link">{link.label}</a>
			))}
			<a href="#yhteystiedot" class="cta cta--light" style="margin-top: 24px; width: 100%; justify-content: center;">
				<span>Pyydä tarjous</span>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>
	</div>
</nav>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		padding: 0;
		overflow: visible;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.navbar.is-scrolled {
		background: rgba(245, 242, 237, 0.95);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		box-shadow: 0 1px 0 rgba(0,0,0,0.06);
	}

	.navbar.is-scrolled .navbar__logo,
	.navbar.is-scrolled .navbar__link,
	.navbar.is-scrolled .navbar__phone {
		color: var(--charcoal);
	}

	.navbar.is-scrolled .navbar__burger span {
		background: var(--charcoal);
	}

	/* Switch CTA to solid green when scrolled */
	.navbar.is-scrolled .navbar__cta {
		background: var(--green-deep);
		box-shadow: none;
		color: var(--white);
	}

	.navbar__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 72px;
	}

	.navbar__logo {
		position: absolute;
		top: 0;
		left: clamp(20px, 4vw, 48px);
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--white);
		border-radius: 0 0 10px 10px;
		padding: 10px 18px 14px;
		box-shadow: 0 4px 20px rgba(0,0,0,0.12);
		transition: box-shadow 0.4s ease;
	}

	.navbar__logo:hover {
		box-shadow: 0 6px 28px rgba(0,0,0,0.18);
	}

	.navbar__logo-img {
		height: 56px;
		width: auto;
		display: block;
	}

	.navbar__logo-spacer {
		width: 140px;
		flex-shrink: 0;
	}

	.navbar__links {
		display: flex;
		gap: 32px;
	}

	.navbar__link {
		color: rgba(255,255,255,0.8);
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		transition: color 0.2s;
	}

	.navbar__link:hover {
		color: var(--white);
	}

	.navbar.is-scrolled .navbar__link:hover {
		color: var(--green-deep);
	}

	.navbar__actions {
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.navbar__phone {
		display: flex;
		align-items: center;
		gap: 6px;
		color: rgba(255,255,255,0.8);
		font-size: 0.875rem;
		font-weight: 500;
		transition: color 0.2s;
	}

	.navbar__phone:hover {
		color: var(--white);
	}

	.navbar.is-scrolled .navbar__phone:hover {
		color: var(--green-deep);
	}

	.navbar__cta {
		font-size: 0.75rem;
		padding: 11px 22px;
	}

	.navbar__burger {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
		z-index: 10;
	}

	.navbar__burger span {
		display: block;
		width: 24px;
		height: 2px;
		background: var(--white);
		transition: all 0.3s ease;
		border-radius: 2px;
	}

	.navbar__mobile {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: var(--charcoal);
		z-index: 5;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.4s ease;
	}

	.navbar__mobile.is-open {
		opacity: 1;
		pointer-events: all;
	}

	.navbar__mobile-links {
		display: flex;
		flex-direction: column;
		justify-content: center;
		height: 100%;
		padding: 0 32px;
	}

	.navbar__mobile-link {
		color: var(--white);
		font-family: var(--font-display);
		font-size: 2rem;
		font-weight: 700;
		padding: 16px 0;
		border-bottom: 1px solid rgba(255,255,255,0.1);
	}

	@media (max-width: 768px) {
		.navbar__links,
		.navbar__phone {
			display: none;
		}

		.navbar__cta {
			display: none;
		}

		.navbar__burger {
			display: flex;
		}

		.navbar__mobile {
			display: block;
		}

		.navbar__logo-spacer {
			display: none;
		}

		.navbar__logo-img {
			height: 44px;
		}
	}
</style>

<script>
	const navbar = document.getElementById('navbar');
	const burger = document.getElementById('navBurger');
	const mobile = document.getElementById('navMobile');

	// Scroll effect
	function handleScroll() {
		if (!navbar) return;
		if (window.scrollY > 80) {
			navbar.classList.add('is-scrolled');
		} else {
			navbar.classList.remove('is-scrolled');
		}
	}

	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();

	// Mobile menu
	burger?.addEventListener('click', () => {
		mobile?.classList.toggle('is-open');
		document.body.style.overflow = mobile?.classList.contains('is-open') ? 'hidden' : '';
	});

	// Close mobile on link click
	document.querySelectorAll('.navbar__mobile-link').forEach(link => {
		link.addEventListener('click', () => {
			mobile?.classList.remove('is-open');
			document.body.style.overflow = '';
		});
	});
</script>
