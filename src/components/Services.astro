---
const services = [
	{
		title: 'Kattoremontit',
		description: 'Kattoremontti on tärkeä investointi, joka parantaa kiinteistön arvoa ja suojaa sitä sääolosuhteilta vuosikymmeniksi eteenpäin. Toteutamme kaikki kattoremonttityöt ammattitaidolla ja laadukkailla materiaaleilla.',
		label: '01',
	},
	{
		title: 'Kattopinnoitukset',
		description: 'Katon pinnoitus on järkevämpi vaihtoehto kuin koko katon uusiminen — se pidentää katon elinikää ja tuo kustannussäästöjä. Käytämme ainoastaan sertifioituja ja kestäviä pinnoitemateriaaleja.',
		label: '02',
	},
	{
		title: 'Stretch sisäkatot',
		description: 'Stretch sisäkatot ovat nykyaikainen ja monikäyttöinen ratkaisu kodin sisätiloihin. Asennukset nopeasti ja siististi — lopputulos on tyylikkäs ja huoltovapaa.',
		label: '03',
	},
];
---

<section class="services" id="palvelut">
	<div class="services__inner container container--wide">
		<div class="services__header reveal">
			<span class="section-label">Palvelumme</span>
			<h2 class="services__title">
				Täydellinen katto,<br/>
				huoleton lopputulos.
			</h2>
		</div>

		<div class="services__accordion reveal">
			{services.map((service, i) => (
				<div class="accordion" data-accordion>
					<button class="accordion__header" aria-expanded={i === 0 ? 'true' : 'false'}>
						<span class="accordion__number">{service.label}</span>
						<span class="accordion__title">{service.title}</span>
						<span class="accordion__toggle">
							<span class="accordion__toggle-line accordion__toggle-line--h"></span>
							<span class="accordion__toggle-line accordion__toggle-line--v"></span>
						</span>
					</button>
					<div class="accordion__body" style={i === 0 ? '' : 'height: 0px;'}>
						<div class="accordion__content">
							<div class="accordion__grid">
								<div class="accordion__image">
									<div class="accordion__image-placeholder">
										<span>{service.title}</span>
									</div>
								</div>
								<div class="accordion__text">
									<p>{service.description}</p>
									<a href="#yhteystiedot" class="link">
										Pyydä tarjous
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
									</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.services {
		padding-top: var(--section-pad);
		padding-bottom: var(--section-pad);
		background: var(--stone);
	}

	.services__inner {
		display: grid;
		grid-template-columns: 0.4fr 1fr;
		gap: clamp(40px, 6vw, 80px);
		align-items: start;
	}

	.services__title {
		font-size: clamp(2rem, 3.5vw, 3rem);
		color: var(--charcoal);
	}

	/* Accordion */
	.services__accordion {
		border-top: 1px solid rgba(28,28,30,0.1);
	}

	.accordion {
		border-bottom: 1px solid rgba(28,28,30,0.1);
	}

	.accordion__header {
		display: flex;
		align-items: center;
		gap: 20px;
		width: 100%;
		padding: 28px 0;
		background: none;
		border: none;
		cursor: pointer;
		text-align: left;
		font-family: inherit;
	}

	.accordion__number {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.8125rem;
		color: var(--green-accent);
		letter-spacing: 0.05em;
		flex-shrink: 0;
		width: 32px;
	}

	.accordion__title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(1.25rem, 2vw, 1.75rem);
		color: var(--charcoal);
		flex: 1;
		letter-spacing: -0.02em;
		transition: color 0.3s;
	}

	.accordion__header:hover .accordion__title {
		color: var(--green-deep);
	}

	.accordion__toggle {
		position: relative;
		width: 20px;
		height: 20px;
		flex-shrink: 0;
	}

	.accordion__toggle-line {
		position: absolute;
		background: var(--charcoal);
		transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
					opacity 0.4s ease;
	}

	.accordion__toggle-line--h {
		top: 50%;
		left: 0;
		width: 100%;
		height: 1.5px;
		transform: translateY(-50%);
	}

	.accordion__toggle-line--v {
		top: 0;
		left: 50%;
		width: 1.5px;
		height: 100%;
		transform: translateX(-50%);
	}

	.accordion__header[aria-expanded="true"] .accordion__toggle-line--v {
		transform: translateX(-50%) rotate(90deg);
		opacity: 0;
	}

	/* Accordion body */
	.accordion__body {
		overflow: hidden;
		transition: height 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.accordion__content {
		padding-bottom: 32px;
	}

	.accordion__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 32px;
		padding-left: 52px;
	}

	.accordion__image-placeholder {
		width: 100%;
		aspect-ratio: 16/10;
		background: linear-gradient(135deg, var(--green-deep), var(--green-dark));
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgba(255,255,255,0.3);
		font-size: 0.875rem;
		clip-path: polygon(0 0, 100% 3%, 100% 97%, 0% 100%);
	}

	.accordion__text p {
		font-size: 1rem;
		color: var(--text-secondary);
		line-height: 1.75;
		margin-bottom: 24px;
	}

	@media (max-width: 900px) {
		.services__inner {
			grid-template-columns: 1fr;
			gap: 40px;
		}

		.accordion__grid {
			grid-template-columns: 1fr;
			padding-left: 0;
		}
	}
</style>

<script>
	// Accordion logic
	document.querySelectorAll('[data-accordion]').forEach(acc => {
		const header = acc.querySelector('.accordion__header') as HTMLButtonElement;
		const body = acc.querySelector('.accordion__body') as HTMLElement;
		const content = acc.querySelector('.accordion__content') as HTMLElement;

		if (!header || !body || !content) return;

		// Initialize first open
		if (header.getAttribute('aria-expanded') === 'true') {
			body.style.height = content.offsetHeight + 'px';
		}

		header.addEventListener('click', () => {
			const isOpen = header.getAttribute('aria-expanded') === 'true';

			// Close all others
			document.querySelectorAll('[data-accordion]').forEach(other => {
				const otherHeader = other.querySelector('.accordion__header') as HTMLButtonElement;
				const otherBody = other.querySelector('.accordion__body') as HTMLElement;
				if (otherHeader && otherBody && other !== acc) {
					otherHeader.setAttribute('aria-expanded', 'false');
					otherBody.style.height = '0px';
				}
			});

			if (isOpen) {
				header.setAttribute('aria-expanded', 'false');
				body.style.height = '0px';
			} else {
				header.setAttribute('aria-expanded', 'true');
				body.style.height = content.offsetHeight + 'px';
			}
		});
	});
</script>
