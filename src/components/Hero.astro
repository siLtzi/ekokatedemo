---
---

<section class="hero" id="hero">
	<div class="hero__bg">
		<video
			class="hero__video"
			src="/heroekokate.mp4"
			autoplay
			muted
			loop
			playsinline
			preload="auto"
			aria-hidden="true"
		></video>
		<div class="hero__overlay"></div>
	</div>

	<!-- Green ridge traces the roofline cut -->
	<svg class="hero__roofline-ridge" viewBox="0 0 1440 100" fill="none" preserveAspectRatio="none" aria-hidden="true">
		<polyline points="0,100 720,20 1440,100" stroke="#7cdc00" stroke-width="3" vector-effect="non-scaling-stroke"/>
	</svg>

	<!-- Roofline divider — fills with next section colour -->
	<svg class="hero__roofline" viewBox="0 0 1440 100" fill="none" preserveAspectRatio="none">
		<path d="M0 100L720 20L1440 100V100H0V100Z" fill="var(--stone)"/>
	</svg>

	<!-- Bottom-anchored content -->
	<div class="hero__content container container--wide">
		<div class="hero__badge">
			<span class="hero__badge-dot"></span>
			Yli 15 vuoden kokemus
		</div>
		<h1 class="hero__title">
			<span class="hero__title-line">Turvallinen katto,</span>
			<span class="hero__title-line hero__title-line--fade">vuosiksi <em>eteenpäin.</em></span>
		</h1>
		<p class="hero__sub">
			Olemme erikoistuneet tiili- ja peltikattojen pinnoituskäsittelyihin,
			katon huoltoon ja remontointiin sekä stretch sisäkattojen asennukseen.
		</p>
		<div class="hero__actions">
			<a href="#yhteystiedot" class="cta cta--light">
				<span>Pyydä tarjous</span>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
			<a href="#palvelut" class="link link--light">
				Tutustu palveluihin
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>
	</div>

	<div class="hero__scroll">
		<div class="hero__scroll-line"></div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: flex-end;
		overflow: hidden;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero__video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(0deg, rgba(10,20,6,0.85) 0%, rgba(10,20,6,0.2) 55%, transparent 100%),
			linear-gradient(90deg, rgba(10,20,6,0.5) 0%, transparent 65%);
	}

	/* Roofline divider */
	.hero__roofline {
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 100%;
		height: clamp(40px, 6vw, 100px);
		z-index: 3;
	}

	.hero__roofline-ridge {
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 100%;
		height: clamp(40px, 6vw, 100px);
		z-index: 4;
		overflow: visible;
		filter: drop-shadow(0 0 6px rgba(124, 220, 0, 0.55));
	}

	.hero__content {
		position: relative;
		z-index: 2;
		padding-top: 0;
		padding-bottom: clamp(80px, 9vw, 140px);
		width: 100%;
	}

	/* Badge — sits just above the title */
	.hero__badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 0.8125rem;
		font-weight: 500;
		color: rgba(255,255,255,0.6);
		letter-spacing: 0.02em;
		margin-bottom: 20px;
	}

	.hero__badge-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--green-accent);
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.5; transform: scale(1.3); }
	}

	/* Title with staggered indentation */
	.hero__title {
		font-size: clamp(2.75rem, 6.5vw, 7.5rem);
		color: var(--white);
		margin-bottom: 28px;
		letter-spacing: -0.04em;
		line-height: 1.0;
		white-space: nowrap;
	}

	.hero__title-line {
		display: block;
		overflow: hidden;
	}

	.hero__title-line--fade {
		color: rgba(255,255,255,0.75);
		font-style: italic;
	}

	.hero__title-line--fade em {
		font-style: inherit;
		color: #7cdc00;
	}

	.hero__sub {
		font-size: clamp(1rem, 1.25vw, 1.125rem);
		color: rgba(255,255,255,0.75);
		max-width: 540px;
		line-height: 1.75;
		margin-bottom: 40px;
	}

	.hero__actions {
		display: flex;
		align-items: center;
		gap: 32px;
		flex-wrap: wrap;
	}

	/* Scroll indicator */
	.hero__scroll {
		position: absolute;
		bottom: clamp(60px, 8vw, 100px);
		right: clamp(24px, 4vw, 48px);
		z-index: 4;
	}

	.hero__scroll-line {
		width: 1px;
		height: 60px;
		background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
		animation: scrollPulse 2s ease-in-out infinite;
	}

	@keyframes scrollPulse {
		0%, 100% { opacity: 0.3; transform: scaleY(1); }
		50% { opacity: 1; transform: scaleY(1.2); }
	}

	@media (max-width: 768px) {
		.hero {
			min-height: 100svh;
		}

		.hero__content {
			padding-bottom: clamp(60px, 12vw, 100px);
		}

		.hero__title {
			white-space: normal;
		}

		.hero__scroll {
			display: none;
		}

		.hero__actions {
			flex-direction: column;
			align-items: flex-start;
			gap: 20px;
		}
	}
</style>
