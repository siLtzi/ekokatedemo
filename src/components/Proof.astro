---
const testimonials = [
	{
		quote: 'Ekokaten ammattilaiset hoitivat kattoremonttimme nopeasti ja laadukkaasti. Erittäin tyytyväinen lopputulokseen ja palveluun.',
		name: 'Matti Virtanen',
		location: 'Oulu',
		role: 'Taloyhtiön hallituksen puheenjohtaja',
	},
	{
		quote: 'Kattopinnoitus toteutettiin ammattimaisesti ja aikataulussa. Katto näyttää kuin uudelta. Suosittelemme lämpimästi.',
		name: 'Anna Korhonen',
		location: 'Liminka',
		role: 'Kiinteistöpäällikkö',
	},
	{
		quote: 'Stretch sisäkatto asennettiin viikossa koko toimistotiloihimme. Lopputulos on upea ja valoisuus parantui huomattavasti.',
		name: 'Juha Mäkelä',
		location: 'Kempele',
		role: 'Toimitusjohtaja',
	},
];

// Duplicate for seamless marquee
const marqueeItems = [...testimonials, ...testimonials];
---

<section class="proof">
	<!-- Full-width image break with text overlay -->
	<div class="proof__image-break reveal">
		<!-- Top ridge -->
		<svg class="proof__ridge proof__ridge--top" viewBox="0 0 1440 60" fill="none" preserveAspectRatio="none" aria-hidden="true">
			<polyline points="0,60 720,0 1440,60" stroke="#7cdc00" stroke-width="3" fill="none"/>
		</svg>

		<img src="/proof.png" alt="Ekokate työkohde" class="proof__image-img" />
		<div class="proof__image-overlay">
			<div class="proof__image-text container">
				<span class="section-label" style="color: rgba(255,255,255,0.5);">Luotettua osaamista</span>
				<h2 class="proof__image-heading">
					Pitkäaikäiset ratkaisut,<br/>
					vastuullisesti toteutettuna.
				</h2>
			</div>
		</div>

		<!-- Bottom ridge -->
		<svg class="proof__ridge proof__ridge--bottom" viewBox="0 0 1440 60" fill="none" preserveAspectRatio="none" aria-hidden="true">
			<polyline points="0,0 720,60 1440,0" stroke="#7cdc00" stroke-width="3" fill="none"/>
		</svg>
	</div>

	<!-- Authority section with asymmetric layout -->
	<div class="proof__authority">
		<div class="proof__authority-inner container container--wide reveal">
			<div class="proof__authority-left">
				<p class="proof__big-text">
					Katon pinnoitus on <em>järkevämpi vaihtoehto</em> kuin koko katon
					uusiminen — se pidentää katon elinikää ja tuo kustannussäästöjä.
				</p>
			</div>
			<div class="proof__authority-right">
				<p class="proof__small-text">
					Palvelemme ammattitaidolla ympäristöä kunnioittaen. Käytämme
					vain sertifioituja materiaaleja ja nykyaikaisia työmenetelmiä
					jotka takaavat pitkäikäisen lopputuloksen.
				</p>
				<a href="#yhteystiedot" class="link">
					Tutustu palveluihimme
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
				</a>
			</div>
		</div>
	</div>

	<!-- Testimonial marquee -->
	<div class="testimonial-marquee">
		<div class="testimonial-marquee__header container reveal">
			<span class="section-label">Asiakkaiden kokemuksia</span>
		</div>
		<div class="testimonial-marquee__track-wrapper">
			<div class="testimonial-marquee__track">
				{marqueeItems.map(t => (
					<div class="testimonial-card">
						<p class="testimonial-card__text">"{t.quote}"</p>
						<div class="testimonial-card__footer">
							<div class="testimonial-card__avatar">
								{t.name.charAt(0)}
							</div>
							<div>
								<span class="testimonial-card__name">{t.name}</span>
								<span class="testimonial-card__meta">{t.role} — {t.location}</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.proof {
		padding: 0;
	}

	/* Full-width image break */
	.proof__image-break {
		position: relative;
		width: 100%;
		overflow: hidden;
		clip-path: polygon(
			0% clamp(40px, 6vw, 100px),
			50% 0%,
			100% clamp(40px, 6vw, 100px),
			100% calc(100% - clamp(40px, 6vw, 100px)),
			50% 100%,
			0% calc(100% - clamp(40px, 6vw, 100px))
		);
	}

	.proof__roof {
		position: absolute;
		left: 0;
		width: 100%;
		height: clamp(40px, 6vw, 100px);
		z-index: 3;
	}

	.proof__roof--top {
		top: 0;
	}

	.proof__roof--bottom {
		bottom: 0;
	}

	.proof__ridge {
		position: absolute;
		left: 0;
		width: 100%;
		height: clamp(40px, 6vw, 100px);
		z-index: 4;
		overflow: visible;
		filter: drop-shadow(0 0 6px rgba(124, 220, 0, 0.55));
	}

	.proof__ridge--top {
		top: 0;
	}

	.proof__ridge--bottom {
		bottom: 0;
	}

	.proof__image-img {
		position: relative;
		width: 100%;
		height: clamp(400px, 50vw, 600px);
		object-fit: cover;
		object-position: center;
		display: block;
		z-index: 1;
	}

	.proof__image-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to right, rgba(28,28,30,0.8) 0%, rgba(28,28,30,0.2) 100%);
		display: flex;
		align-items: center;
		z-index: 2;
	}

	.proof__image-heading {
		font-size: clamp(2rem, 4vw, 3.5rem);
		color: var(--white);
		max-width: 600px;
	}

	/* Authority — two-column asymmetric */
	.proof__authority {
		padding: var(--section-pad) 0;
		background: var(--stone);
	}

	.proof__authority-inner {
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		gap: clamp(40px, 6vw, 100px);
		align-items: start;
	}

	.proof__big-text {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: clamp(1.5rem, 2.5vw, 2rem);
		color: var(--charcoal);
		line-height: 1.45;
		letter-spacing: -0.01em;
	}

	.proof__big-text em {
		font-style: normal;
		color: var(--green-deep);
	}

	.proof__small-text {
		font-size: 1rem;
		color: var(--text-secondary);
		line-height: 1.75;
		margin-bottom: 24px;
	}

	/* Testimonial marquee */
	.testimonial-marquee {
		background: var(--white);
		padding: var(--section-pad) 0;
		overflow: hidden;
	}

	.testimonial-marquee__header {
		margin-bottom: 40px;
	}

	.testimonial-marquee__track-wrapper {
		overflow: hidden;
		mask-image: linear-gradient(90deg, transparent, black 5%, black 95%, transparent);
		-webkit-mask-image: linear-gradient(90deg, transparent, black 5%, black 95%, transparent);
	}

	.testimonial-marquee__track {
		display: inline-flex;
		gap: 24px;
		animation: testimonialScroll 40s linear infinite;
		padding: 8px 0;
	}

	.testimonial-marquee__track:hover {
		animation-play-state: paused;
	}

	@keyframes testimonialScroll {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	.testimonial-card {
		flex-shrink: 0;
		width: 380px;
		padding: 32px;
		background: var(--stone);
		border-radius: 0;
		clip-path: polygon(0 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%);
		transition: transform 0.3s ease;
	}

	.testimonial-card:hover {
		transform: translateY(-4px);
	}

	.testimonial-card__text {
		font-size: 0.9375rem;
		color: var(--text-primary);
		line-height: 1.7;
		margin-bottom: 24px;
		font-style: italic;
	}

	.testimonial-card__footer {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.testimonial-card__avatar {
		width: 36px;
		height: 36px;
		background: var(--green-deep);
		color: var(--white);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.875rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.testimonial-card__name {
		display: block;
		font-weight: 600;
		font-size: 0.875rem;
		color: var(--charcoal);
	}

	.testimonial-card__meta {
		display: block;
		font-size: 0.75rem;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.proof__authority-inner {
			grid-template-columns: 1fr;
			gap: 32px;
		}

		.testimonial-card {
			width: 300px;
		}
	}
</style>
